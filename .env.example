DATABASE_URL="postgresql://username:password@host:5432/maidconnect?schema=public"

JWT_SECRET="replace-with-a-long-random-secret"
PORT=8000
CLIENT_ORIGIN=https://your-frontend-domain.com

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_NOTIFICATIONS_ENABLED=true

FLW_PUBLIC_KEY=your-flutterwave-public-key
FLW_SECRET_KEY=your-flutterwave-secret-key
FLW_ENCRYPTION_KEY=your-flutterwave-encryption-key

PAYPACK_API_KEY=your-paypack-api-key
PAYPACK_API_SECRET=your-paypack-api-secret
PAYPACK_API_BASE_URL=https://payments.paypack.rw/api
PAYPACK_CURRENCY=RWF
PAYPACK_TEST_MODE=false

PAWAPAY_API_KEY=your-pawapay-api-key
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_WEBHOOK_SECRET_HASH=your-pawapay-webhook-secret

# Optional override: paypack | pawapay | intouchpay
PAYMENT_GATEWAY_MODE=
JOB_POST_FEE_PERCENTAGE=0.1
INTOUCHPAY_BASE_URL=https://www.intouchpay.co.rw/api
INTOUCHPAY_USERNAME=your-intouchpay-username
INTOUCHPAY_ACCOUNT_NO=your-intouchpay-account-number
INTOUCHPAY_PARTNER_PASSWORD=your-intouchpay-partner-password
INTOUCHPAY_CALLBACK_URL=https://your-backend-domain/api/payments/webhook/deposit
INTOUCHPAY_SANDBOX=false
INTOUCHPAY_WITHDRAW_CHARGE=1
INTOUCHPAY_SID=1
