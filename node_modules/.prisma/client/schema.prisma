// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYER
  MAID
  ADMIN
}

enum JobStatus {
  OPEN
  CLOSED
  FILLED
}

enum ContractStatus {
  DRAFT
  PENDING
  SIGNED
  ACTIVE
  COMPLETED
  TERMINATED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  password         String
  role             Role      @default(EMPLOYER)
  fullName         String?
  phone            String?
  address          String?
  profileImage     String?
  description      String? // Bio or company description
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?

  // Employer specifics
  jobs                Job[]
  contractsAsEmployer Contract[] @relation("EmployerContracts")
  reviewsWritten      Review[]   @relation("WrittenReviews")

  // Maid specifics (extended)
  dob                 DateTime?
  gender              String?
  nidNumber           String?
  maritalStatus       String?
  childrenCount       Int?      @default(0)
  country             String?   @default("Rwanda")
  provinceDistrict    String?
  sectorCellVillage   String?
  willingToRelocate   Boolean?  @default(false)
  yearsExperience     Int?      @default(0)
  prevEmployer        String?
  prevEmployerContact String?
  workTypes           String[]  @default([])
  reasonForLeaving    String?
  highestEducation    String?
  languages           String?
  specialSkills       String[]  @default([])
  drivingLicense      Boolean?  @default(false)
  availabilityType    String?
  startDate           DateTime?
  preferredHours      String?
  expectedSalary      Float?
  salaryNegotiable    Boolean?  @default(true)
  nidPhoto            String?
  insurancePhoto      String?
  emergencyName       String?
  emergencyRelation   String?
  emergencyPhone      String?

  applications    Application[]
  contractsAsMaid Contract[]    @relation("MaidContracts")
  reviewsReceived Review[]      @relation("ReceivedReviews")

  // Disputes
  disputesFiled   Dispute[]         @relation("FiledDisputes")
  disputesAgainst Dispute[]         @relation("DisputesAgainst")
  notifications   Notification[]
  unlockedMaids   UnlockedProfile[] @relation("EmployerUnlocks")
  unlockedBy      UnlockedProfile[] @relation("MaidUnlockRecords")
  payments        Payment[]         @relation("EmployerPayments")

  // Messaging & Encryption
  publicKey     String? // RSA Public Key for E2EE
  conversations Conversation[] @relation("UserConversations")
  sentMessages  Message[]      @relation("SentMessages")
}

model Conversation {
  id            Int       @id @default(autoincrement())
  participants  User[]    @relation("UserConversations")
  messages      Message[]
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       Int
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String // Encrypted message content (AES)
  encryptedKey   String // AES key encrypted with recipient's RSA Public Key
  senderKey      String? // AES key encrypted with sender's RSA Public Key (for history)
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model UnlockedProfile {
  id         Int      @id @default(autoincrement())
  employerId Int
  maidId     Int
  employer   User     @relation("EmployerUnlocks", fields: [employerId], references: [id])
  maid       User     @relation("MaidUnlockRecords", fields: [maidId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([employerId, maidId])
}

model Payment {
  id            Int      @id @default(autoincrement())
  transactionId String   @unique // Flutterwave transaction_id
  employerId    Int
  employer      User     @relation("EmployerPayments", fields: [employerId], references: [id])
  maidId        Int? // Optional, for profile unlocks
  amount        Float
  currency      String   @default("RWF")
  status        String // e.g. "SUCCESSFUL", "FAILED"
  type          String   @default("PROFILE_UNLOCK") // e.g. "PROFILE_UNLOCK", "SUBSCRIPTION"
  createdAt     DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String // e.g. "APPLICATION", "CONTRACT", "REVIEW", "SYSTEM"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Job {
  id           Int           @id @default(autoincrement())
  title        String
  description  String
  requirements String?
  location     String
  salaryMin    Float?
  salaryMax    Float?
  status       JobStatus     @default(OPEN)
  employerId   Int
  employer     User          @relation(fields: [employerId], references: [id])
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id          Int               @id @default(autoincrement())
  jobId       Int
  job         Job               @relation(fields: [jobId], references: [id])
  maidId      Int
  maid        User              @relation(fields: [maidId], references: [id])
  status      ApplicationStatus @default(PENDING)
  coverLetter String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Contract {
  id          Int            @id @default(autoincrement())
  employerId  Int
  employer    User           @relation("EmployerContracts", fields: [employerId], references: [id])
  maidId      Int
  maid        User           @relation("MaidContracts", fields: [maidId], references: [id])
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  salary      Float
  terms       String?
  status      ContractStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  disputes Dispute[]
  review   Review?
}

model Dispute {
  id            Int      @id @default(autoincrement())
  contractId    Int
  contract      Contract @relation(fields: [contractId], references: [id])
  complainantId Int
  complainant   User     @relation("FiledDisputes", fields: [complainantId], references: [id])
  respondentId  Int
  respondent    User     @relation("DisputesAgainst", fields: [respondentId], references: [id])
  reason        String
  description   String
  status        String   @default("OPEN") // OPEN, RESOLVED, CLOSED
  resolution    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id         Int      @id @default(autoincrement())
  contractId Int      @unique
  contract   Contract @relation(fields: [contractId], references: [id])
  reviewerId Int
  reviewer   User     @relation("WrittenReviews", fields: [reviewerId], references: [id])
  revieweeId Int
  reviewee   User     @relation("ReceivedReviews", fields: [revieweeId], references: [id])
  rating     Int // 1-5
  comment    String?
  createdAt  DateTime @default(now())
}
